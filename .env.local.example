# Get your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (v2.0 Persistent Chat Platform)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NOTE: Supabase is transitioning to NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# Both names work. Use ANON_KEY for now.

# Vercel Cron (keep-alive route protection)
CRON_SECRET=generate-with-openssl-rand-hex-16

# Token usage logging (dev only — writes to usage.jsonl)
# LOG_USAGE=true
